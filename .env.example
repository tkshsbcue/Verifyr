# Copy to .env and fill in. Loaded automatically if python-dotenv is installed.

# ---- VLM (default provider: openai) ----
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=sk-...
# To use Claude instead, set VLM_PROVIDER=anthropic, VLM_MODEL=claude-opus-4-8,
# and ANTHROPIC_API_KEY=...
# ANTHROPIC_API_KEY=

# Optional model knobs (defaults come from prompt.json config)
# VLM_TEMPERATURE=0
# VLM_MAX_TOKENS=1024

# ---- Appium / device ----
APPIUM_SERVER_URL=http://127.0.0.1:4723
ANDROID_AVD=Pixel_7_API_34
ANDROID_DEVICE_NAME=Android Emulator
# ANDROID_PLATFORM_VERSION=14
# ANDROID_UDID=emulator-5554
# APPIUM_NO_RESET=true
# APPIUM_NEW_COMMAND_TIMEOUT=120

# ---- App under test: set EITHER package+activity OR an apk path ----
APP_PACKAGE=com.example.app
APP_ACTIVITY=com.example.app.MainActivity
# APP_PATH=/absolute/path/to/app.apk

# ---- Misc ----
# PROMPT_CONFIG=idea/prompt0.json
# RUNS_DIR=runs
