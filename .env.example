# Copy to .env and fill in. Loaded automatically if python-dotenv is installed.

# ---- VLM (default provider: openai) ----
VLM_PROVIDER=openai
VLM_MODEL=gpt-5.5
OPENAI_API_KEY=sk-...
# To use Claude instead, set VLM_PROVIDER=anthropic, VLM_MODEL=claude-opus-4-8,
# and ANTHROPIC_API_KEY=...
# ANTHROPIC_API_KEY=

# Optional model knobs (defaults come from prompt.json config)
# VLM_TEMPERATURE=0
# VLM_MAX_TOKENS=1024

# ---- Appium / device ----
APPIUM_SERVER_URL=http://127.0.0.1:4723
ANDROID_AVD=Pixel_7_API_34
ANDROID_DEVICE_NAME=Android Emulator
# ANDROID_PLATFORM_VERSION=14
# ANDROID_UDID=emulator-5554
# APPIUM_NO_RESET=true
# APPIUM_NEW_COMMAND_TIMEOUT=120

# ---- App under test: set EITHER package+activity OR an apk path ----
APP_PACKAGE=com.example.app
APP_ACTIVITY=com.example.app.MainActivity
# APP_PATH=/absolute/path/to/app.apk

# ---- Login automation (optional; runs as a deterministic pre-step) ----
# LOGIN_FLOW=dev_impersonate            # the only flow implemented so far
# IMPERSONATE_KEY=eyJhbGciOi...          # Supabase service-role key (secret; stays local)
# IMPERSONATE_USER=                      # substring of the user to pick; blank = first user

# ---- Misc ----
# PROMPT_CONFIG=idea/prompt0.json
# RUNS_DIR=runs

# ---- Server / GUI (server/main.py) ----
# DATABASE_URL=sqlite:///./verifyr.db        # or postgresql+psycopg://user:pass@host/db
# JWT_SECRET=change-me-to-a-32+-byte-random-string
# JWT_EXPIRE_MINUTES=1440
# CORS_ORIGINS=http://localhost:5173
# Optional SMTP for regression alerts (else alerts are logged):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_FROM=verifyr@yourco.com

# ---- Docker (docker compose up) ----
# OPENAI_API_KEY above is required. Recommended for Docker:
JWT_SECRET=change-me-to-a-32+-byte-random-string
# Auto-create an admin user on first boot (so you can log in immediately):
ADMIN_EMAIL=admin@verifyr.local
ADMIN_PASSWORD=changeme123
# SEED_CHECKS=checks.json                     # import sample checks on first boot
# Where the app reaches Appium:
#   macOS/Windows host-run Appium (default):
APPIUM_SERVER_URL=http://host.docker.internal:4723
#   Bundled emulator (docker compose --profile emulator up):
# APPIUM_SERVER_URL=http://emulator:4723
